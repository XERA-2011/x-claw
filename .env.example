# ┌──────────────────────────────────────────────────────────────────┐
# │  OpenClaw 环境变量配置                                          │
# │  复制此文件为 .env 后修改: cp .env.example .env                  │
# │  ⚠️ .env 文件包含敏感信息，已在 .gitignore 中排除               │
# └──────────────────────────────────────────────────────────────────┘

# ── 认证令牌 (必填) ──
# 运行 setup.sh 会自动生成；也可手动设置
# 生成方法: openssl rand -hex 32
OPENCLAW_GATEWAY_TOKEN=

# ── AI API Keys ──
# Google AI Studio / Gemini API Key (可选,使用自己的更高额度)
GOOGLE_API_KEY=

# ── 数据目录 ──
# 配置、记忆、API Key 存储位置
OPENCLAW_CONFIG_DIR=~/.openclaw
# Agent 工作空间（Agent 可以读写的目录）
OPENCLAW_WORKSPACE_DIR=~/openclaw/workspace

# ── 端口设置 ──
OPENCLAW_GATEWAY_PORT=18789
OPENCLAW_BRIDGE_PORT=18790

# ── 安全设置 (⚠️ 无特殊需求请勿修改) ──
# loopback = 仅容器内部访问（浏览器无法打开 Control UI）
# lan      = 允许宿主机浏览器 + CLI 访问（配合 127.0.0.1 端口绑定仍然安全）
OPENCLAW_GATEWAY_BIND=lan

# ── Docker 镜像 ──
# 默认本地构建；可改为 ghcr.io/openclaw/openclaw:latest 使用预构建镜像
OPENCLAW_IMAGE=openclaw:local

# ── 沙箱模式 (默认禁用) ──
# 启用需挂载 docker.sock，有安全风险
# OPENCLAW_SANDBOX=0
